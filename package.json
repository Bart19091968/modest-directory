{
  "name": "modest-directory",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "npx prisma db push --skip-generate && npx tsx prisma/cleanup-modest-fashion.ts && next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:quality": "npx tsx prisma/seed-quality.ts",
    "db:cleanup:modest-fashion": "npx tsx prisma/cleanup-modest-fashion.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@prisma/client": "^6.7.0",
    "resend": "^3.2.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "prisma": "^6.7.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.17",
    "tsx": "^4.7.0"
  }
}
